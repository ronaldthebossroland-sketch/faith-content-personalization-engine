HOST=0.0.0.0
PORT=5000
APP_NAME="Healing School Faith Personalization Engine"
DATA_RETENTION_DAYS=365
DECAY_LAMBDA=0.02
ADMIN_API_KEY=change_me_dev_admin_key
APPROVED_EVENT_SOURCES=healing_school_app,healing_streams_registration_page,approved_healing_school_campaign,official_ministry_website,approved_email_campaign
STORAGE_DRIVER=sqlite
DATA_FILE_PATH=data/local-store.sqlite
CORS_ORIGIN=*

# Production database on Supabase:
# STORAGE_DRIVER=supabase
# SUPABASE_URL=https://your-project-ref.supabase.co
# Prefer a Supabase secret key (sb_secret_...) for backend services.
# Legacy service_role keys also work if you set SUPABASE_SERVICE_ROLE_KEY instead.
# SUPABASE_SECRET_KEY=sb_secret_your_backend_key

# Frontend deploys on Vercel use this at build time:
# FAITH_ENGINE_API_URL=https://your-render-service.onrender.com
GEMINI_MODEL=gemini-2.5-flash
# DEV ONLY — bypasses consent and source checks for local phone testing. Never true in production.
BYPASS_CONSENT=false

# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
